# =================================
# Environment Variables for Airflow
# =================================
# chmod 600 .env  # Secure permissions
# SECURITY WARNING: This file contains sensitive credentials
# - Add .env to .gitignore to prevent accidental commits
# - Use strong passwords in production environments
# - Rotate credentials regularly

# ----------------------------------------
# PostgreSQL Database Credentials
# ----------------------------------------
# NOTE: dotenv / docker compose expects KEY=VALUE (no spaces).
POSTGRES_USER=airflow
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=airflow

# ----------------------------------------
# Airflow Fernet Key
# ----------------------------------------
# Used to encrypt connection passwords and sensitive data in Airflow
# Generate a new key using:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=REPLACE_ME

# ----------------------------------------
# Worker IP
# ----------------------------------------
# NOTE: KEY=VALUE (no spaces)
HK_IP=REPLACE_ME
JP_IP=REPLACE_ME
US_IP=REPLACE_ME

# ----------------------------------------
# Optional: Airflow Admin User (for initial setup)
# ----------------------------------------
# Uncomment these if you want to auto-create an admin user
# AIRFLOW_ADMIN_USERNAME=admin
# AIRFLOW_ADMIN_PASSWORD=admin_password_2024
# AIRFLOW_ADMIN_EMAIL=admin@example.com
# AIRFLOW_ADMIN_FIRSTNAME=Admin
# AIRFLOW_ADMIN_LASTNAME=User
